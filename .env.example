# GHOST Agent Configuration
# Copy to .env and fill in real values
# NEVER commit .env to GitHub

# 0G Compute Router API key (from pc.testnet.0g.ai)
ROUTER_API_KEY=sk-your-key-here

# Agent wallet private key
PRIVATE_KEY=0xyourprivatekeyhere

# 0G Chain testnet RPC
RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage indexer
INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai

# API server port
PORT=3001
